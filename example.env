# App environment
NODE_ENV=development

# Security
DEPLOY_SECRET=replace-with-a-long-random-secret

# URLs
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
DEPLOY_BACKEND_URL=http://localhost:3000

# Auth mode A: GitHub App (recommended)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Provide exactly one of the following:
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY_BASE64=

# Auth mode B: Personal Access Token fallback
GITHUB_TOKEN=

# Feature flags
ENABLE_GITHUB_PAGES=true
ENABLE_WORKFLOW_INJECTION=false

# Optional database configuration (Neon + Drizzle)
# Current runtime still uses server/db.json until storage migration is wired.
DB_PROVIDER=json
# Use pooled Neon URL for runtime queries.
DATABASE_URL=postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
# Use direct Neon URL for migrations when possible.
DIRECT_DATABASE_URL=postgresql://<user>:<password>@<project>.<region>.aws.neon.tech/<db>?sslmode=require
